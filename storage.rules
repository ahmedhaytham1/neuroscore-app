// storage.rules
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Patient videos ──────────────────────────────────────
    // Path: videos/{patientId}/{filename}
    match /videos/{patientId}/{allPaths=**} {
      // Only the patient themselves can upload their videos
      allow write: if request.auth != null &&
        request.auth.uid == patientId &&
        request.resource.size < 100 * 1024 * 1024 && // max 100 MB
        request.resource.contentType.matches('video/.*');

      // Patient and their assigned doctor can read
      allow read: if request.auth != null;
    }
  }
}
